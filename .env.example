# Frontend runtime variables (required by this app)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-public-key

# Frontend URL used in auth callback allow-lists/documentation
VITE_APP_URL=http://localhost:5173

# OAuth callback references (used when configuring providers, not read by Vite directly)
SUPABASE_AUTH_CALLBACK_URL=https://your-project-ref.supabase.co/auth/v1/callback
GOOGLE_OAUTH_REDIRECT_URI=https://your-project-ref.supabase.co/auth/v1/callback

# Comma-separated URLs to add in Supabase Auth > URL Configuration
SUPABASE_AUTH_ADDITIONAL_REDIRECT_URLS=http://localhost:5173,https://your-production-domain.com
